{
  "name": "afk",
  "version": "0.1.0",
  "private": true,
  "description": "Personal vacation tracker for people whose to-do list is currently 'leave'.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "routes:generate": "tsr generate",
    "lint": "npm run routes:generate && tsc -b --noEmit && eslint .",
    "fmt": "prettier -w . && eslint . --fix",
    "cf-typegen": "wrangler types ./worker/worker-configuration.d.ts"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.100.0",
    "@tanstack/react-router": "^1.167.0",
    "hono": "^4.12.0",
    "ical-generator": "^10.2.0",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/vite-plugin": "^1.1.0",
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@cloudflare/workers-types": "^4.20260502.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.0",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/router-cli": "^1.166.40",
    "@tanstack/router-plugin": "^1.167.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.0",
    "wrangler": "^4.87.0"
  },
  "engines": {
    "node": ">=22"
  }
}
